{
  "name": "github-project-manager",
  "version": "0.2.0",
  "description": "GitHub Project V2 manager - CLI + Web UI for task management with Claude Code",
  "bin": {
    "gpm": "./apps/cli/bin/gpm.js"
  },
  "files": [
    "apps/cli/bin",
    "apps/cli/dist",
    "apps/backend/dist",
    "apps/frontend/dist",
    "templates"
  ],
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:backend": "yarn workspace @gpm/backend dev",
    "dev:frontend": "yarn workspace @gpm/frontend dev",
    "build:backend": "yarn workspace @gpm/backend build",
    "build:frontend": "yarn workspace @gpm/frontend build",
    "build:cli": "yarn workspace @gpm/cli build",
    "build": "yarn build:backend && yarn build:cli && yarn build:frontend",
    "gpm": "yarn workspace @gpm/cli start",
    "start": "yarn workspace @gpm/backend start:prod",
    "prepublishOnly": "yarn build"
  },
  "keywords": [
    "github",
    "project",
    "manager",
    "cli",
    "kanban",
    "task",
    "claude-code"
  ],
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/serve-static": "^5.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@octokit/graphql": "^9.0.3",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "yarn@3.8.7"
}
